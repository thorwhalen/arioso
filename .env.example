# Arioso configuration
# Copy this file to .env and fill in your credentials.
# NEVER commit .env to version control.

# --- Suno (cookie-based / direct access) ---
# Extract from browser DevTools after logging into suno.com/create
# See CLAUDE.md for detailed extraction instructions.
SUNO_COOKIE=

# Optional: 2Captcha API key for solving hCaptcha challenges
# Required if Suno presents CAPTCHAs (common from datacenter IPs / Docker)
# Get a key at https://2captcha.com
TWOCAPTCHA_KEY=

# --- Suno (commercial proxy) ---
# API key from your proxy provider (sunoapi.org, MusicAPI.ai, CometAPI, etc.)
SUNO_API_KEY=

# Base URL of the proxy API (e.g., https://api.sunoapi.org)
SUNO_API_BASE=
